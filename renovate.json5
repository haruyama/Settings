{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':semanticCommitTypeAll(deps)',
    ':dependencyDashboard',
  ],
  timezone: 'Asia/Tokyo',
  labels: ['dependencies'],
  // Supply-chain cooldown: wait 3 days after a release before opening a PR.
  // Mirrors .npmrc `min-release-age=3`; lets newly compromised releases be caught
  // and yanked before we pull them.
  minimumReleaseAge: '3 days',
  internalChecksFilter: 'strict',
  packageRules: [
    {
      // The asdf manager tracks nodejs with `versioning: node`, whose default
      // `ignoreUnstable: true` skips every non-LTS (Current) release. We want the
      // latest stable/Current line (e.g. 26.x before it becomes LTS in Oct 2026),
      // so opt into unstable node releases. Still node-schedule-aware ordering.
      description: 'Follow the latest Node.js stable (Current) line, not just LTS, in .tool-versions',
      matchManagers: ['asdf'],
      matchDepNames: ['node'],
      ignoreUnstable: false,
    },
    {
      description: 'Disable major bumps for Go modules with /vN in path; major bump also changes the import path and must be done manually',
      matchDatasources: ['go'],
      matchPackageNames: ['/\\/v\\d+$/'],
      matchUpdateTypes: ['major'],
      enabled: false,
    },
    {
      // Neovim/Vim plugins are pinned to their default-branch HEAD via
      // jetpack.toml git-refs digests. One PR per plugin (no groupName).
      // These digest bumps have no release timestamp, so minimumReleaseAge
      // can't apply a per-commit cooldown; as a coarse stand-in we only open
      // these PRs early Monday (JST, via the repo-level Asia/Tokyo timezone).
      description: 'One PR per jetpack (Neovim/Vim) plugin, opened only early Monday (JST)',
      matchFileNames: ['**/jetpack.toml'],
      matchDatasources: ['git-refs'],
      minimumReleaseAgeBehaviour: 'timestamp-optional',
      schedule: ['before 5am on monday'],
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      description: 'Pinned tool versions in Makefile (FOO_VERSION := vX.Y.Z)',
      managerFilePatterns: ['/(^|/)Makefile$/'],
      matchStrings: [
        '# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+?)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+allowedVersions=(?<allowedVersions>\\S+))?[ \\t]*\\n[A-Z0-9_]+_VERSION\\s*:=\\s*(?<currentValue>\\S+)',
      ],
      versioningTemplate: '{{#if versioning}}{{versioning}}{{else}}semver{{/if}}',
    },
    {
      customType: 'regex',
      description: 'Git-refs SHA pins in Makefile (FOO_SHA := <40-hex>)',
      managerFilePatterns: ['/(^|/)Makefile$/'],
      matchStrings: [
        '# renovate: datasource=git-refs depName=(?<depName>\\S+) branch=(?<currentValue>\\S+)[ \\t]*\\n[A-Z0-9_]+_SHA\\s*:=\\s*(?<currentDigest>[a-f0-9]{40})',
      ],
      datasourceTemplate: 'git-refs',
    },
    {
      customType: 'regex',
      description: 'asdf tools in .tool-versions not handled by Renovate\'s asdf manager (e.g. neovim, fzf)',
      managerFilePatterns: ['/(^|/)\\.tool-versions$/'],
      matchStrings: [
        '# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+?)(?:\\s+versioning=(?<versioning>\\S+))?(?:\\s+extractVersion=(?<extractVersion>\\S+))?[ \\t]*\\n\\S+\\s+(?<currentValue>\\S+)',
      ],
      versioningTemplate: '{{#if versioning}}{{versioning}}{{else}}semver{{/if}}',
    },
    {
      // Convention: place the renovate comment immediately before `[[plugins]]`,
      // and put `commit = '<sha>'` on the line right after `repo = '...'`.
      customType: 'regex',
      description: 'Vim-jetpack plugin commit pins in jetpack.toml',
      managerFilePatterns: ['/(^|/)jetpack\\.toml$/'],
      matchStrings: [
        '# renovate: datasource=git-refs depName=(?<depName>\\S+) branch=(?<currentValue>\\S+)[ \\t]*\\n\\[\\[plugins\\]\\]\\nrepo\\s*=\\s*[\'"][^\'"]+[\'"]\\ncommit\\s*=\\s*[\'"](?<currentDigest>[a-f0-9]{40})[\'"]',
      ],
      datasourceTemplate: 'git-refs',
    },
    {
      // asdf-nodejs installs these globally on every Node.js install. Each line
      // is `name@version` (the parser strips `#` comment lines), so we pin every
      // package and let Renovate bump them. Generic match: no per-line comment.
      customType: 'regex',
      description: 'Global npm packages pinned as name@version in .default-npm-packages',
      managerFilePatterns: ['/(^|/)\\.default-npm-packages$/'],
      matchStrings: [
        '(?<depName>(?:@[^/\\s@]+/)?[^/\\s@]+)@(?<currentValue>[^\\s@]+)',
      ],
      datasourceTemplate: 'npm',
      versioningTemplate: 'npm',
    },
  ],
}
